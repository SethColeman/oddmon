<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Oddmon.Core\Oddmon.Core.csproj" />
  </ItemGroup>

  <!-- Bundle the default sound set: any WAVs in assets/sounds copy to output\sounds. -->
  <ItemGroup>
    <None Include="..\..\assets\sounds\*.wav" Link="sounds\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>oddmon</AssemblyName>
  </PropertyGroup>

</Project>
